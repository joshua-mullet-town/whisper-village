    echo ""
}

# ============================================================================
# MAIN LOOP
# ============================================================================
main() {
    while true; do
        if ! is_installed; then
            screen_not_installed
        elif is_running; then
            screen_running
        else
            screen_stopped
        fi

        read -rsn1 key

        case $key in
            i|I)
                if ! is_installed; then
                    do_install
                fi
                ;;
            s|S)
                if is_installed && ! is_running; then
                    do_start
                fi
                ;;
            k|K)
                if is_running; then
                    do_stop
                fi
                ;;
            r|R)
                if is_running; then
                    do_stop
                    do_start
                fi
                ;;
            o|O)
                if is_running; then
                    open "http://localhost:$PORT"
                fi
                ;;
            u|U)
                if is_installed; then
                    do_update
                fi
                ;;
            l|L)
                if is_installed; then
                    do_logs
                fi
                ;;
            d|D)
                if is_installed; then
                    open "$HOMESTEAD_DIR"
                fi
                ;;
            x|X)
                if is_installed; then
                    do_uninstall
                fi
                ;;
            q|Q)
                clear_screen
                echo ""
                echo -e "  ${ORANGE}Homestead CLI closed.${RESET}"
                if is_running; then
                    echo -e "  ${GREEN}Server still running at http://localhost:$PORT${RESET}"
                fi
                echo ""
                exit 0
                ;;
        esac
    done
}

# ============================================================================
# ENTRY POINT
# ============================================================================
main "$@"
